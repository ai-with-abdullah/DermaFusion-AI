*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.spec

# ─── Environments ─────────────────────────────────────────────────────────────
.env
.venv
venv/
env/

# ─── Jupyter / IPython ────────────────────────────────────────────────────────
.ipynb_checkpoints/
